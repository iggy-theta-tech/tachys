{
  "version": 6,
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug (ASAN + UBSAN)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_FLAGS": "-O0 -g -fsanitize=address,undefined -DTACHYS_DEBUG=1 -fno-omit-frame-pointer"
      }
    },
    {
      "name": "release",
      "displayName": "Release (LTO + native)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_FLAGS": "-O3 -march=native -flto -DNDEBUG"
      }
    },
    {
      "name": "benchmark",
      "displayName": "Benchmark (optimised + symbols)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/benchmark",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_CXX_FLAGS": "-O3 -g"
      }
    }
  ],
  "buildPresets": [
    { "name": "debug",     "configurePreset": "debug" },
    { "name": "release",   "configurePreset": "release" },
    { "name": "benchmark", "configurePreset": "benchmark" }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "release",
      "configurePreset": "release",
      "output": { "outputOnFailure": true }
    }
  ]
}
